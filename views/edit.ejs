<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit your chat</title>

</head>
<body>

    <p>edit your chat: <%=chat.id%><p>
    <p>This chat was sent from<b> <%=chat.from%></b> to <b><%=chat.to%></b></p>

    <!-- form to edit the form -->
    <!-- In form we can only use get or post but as we have to use PUT request we will use override method -->
    <form method="POST" action="/chats/<%=chat._id%>?_method=PUT"> 
        <textarea name="msg" rows="6" cols="50"><%=chat.msg%></textarea>
        <br>
        <button>Edit</button>
    </form>

 
    
</body>
</html>